<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- سطح عرض الفيديو -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="surface_view" />

    <!-- طبقة اللمس والإيماءات (تقديم/ترجيع بالدبل تاب، سحب للصوت/السطوع) -->
    <FrameLayout
        android:id="@+id/gestureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- مؤشر السطوع/الصوت/التقديم عند السحب أو الدبل تاب -->
    <LinearLayout
        android:id="@+id/gestureIndicatorContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_rounded_dark"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/gestureIndicatorIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_volume" />

        <TextView
            android:id="@+id/gestureIndicatorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            tools:text="70%"
            xmlns:tools="http://schemas.android.com/tools" />

    </LinearLayout>

    <!-- مؤشر التحميل -->
    <ProgressBar
        android:id="@+id/bufferingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <!-- الشريط العلوي: رجوع + عنوان الفيديو + قفل -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_gradient_top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="12dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ripple_circle"
            android:src="@drawable/ic_back"
            android:contentDescription="@string/back" />

        <TextView
            android:id="@+id/videoTitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="اسم الفيديو"
            xmlns:tools="http://schemas.android.com/tools" />

        <ImageButton
            android:id="@+id/speedButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ripple_circle"
            android:src="@drawable/ic_speed"
            android:contentDescription="@string/speed" />

        <ImageButton
            android:id="@+id/lockButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/ripple_circle"
            android:src="@drawable/ic_unlock"
            android:contentDescription="@string/lock" />

    </LinearLayout>

    <!-- زر فتح القفل يظهر فقط عندما تكون الشاشة مقفلة -->
    <ImageButton
        android:id="@+id/unlockOnlyButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:background="@drawable/bg_rounded_dark"
        android:src="@drawable/ic_lock"
        android:visibility="gone"
        android:contentDescription="@string/unlock" />

    <!-- الشريط السفلي: شريط التقديم + أزرار التحكم -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_gradient_bottom"
        android:orientation="vertical"
        android:paddingHorizontal="12dp"
        android:paddingTop="20dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/currentTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="00:00"
                xmlns:tools="http://schemas.android.com/tools" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="8dp"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/totalTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                tools:text="00:00"
                xmlns:tools="http://schemas.android.com/tools" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="6dp">

            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_previous"
                android:contentDescription="@string/previous" />

            <ImageButton
                android:id="@+id/rewindButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_rewind10"
                android:contentDescription="@string/rewind" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_pause"
                android:contentDescription="@string/play" />

            <ImageButton
                android:id="@+id/forwardButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_forward10"
                android:contentDescription="@string/forward" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_next"
                android:contentDescription="@string/next" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
