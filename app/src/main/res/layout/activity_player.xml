<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- سطح عرض الفيديو -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="surface_view" />

    <!-- طبقة اللمس والإيماءات -->
    <FrameLayout
        android:id="@+id/gestureOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- مؤشر السطوع/الصوت/التقديم -->
    <LinearLayout
        android:id="@+id/gestureIndicatorContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_rounded_dark"
        android:paddingHorizontal="18dp"
        android:paddingVertical="12dp"
        android:visibility="gone"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/gestureIndicatorIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_volume" />

        <TextView
            android:id="@+id/gestureIndicatorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            tools:text="70%" />

    </LinearLayout>

    <!-- زر تشغيل مركزي كبير (يظهر مع الأشرطة) -->
    <ImageView
        android:id="@+id/centerPlayButton"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="center"
        android:background="@drawable/bg_play_button_gradient"
        android:src="@drawable/ic_play_hero"
        android:padding="22dp"
        android:elevation="6dp" />

    <!-- مؤشر التحميل -->
    <ProgressBar
        android:id="@+id/bufferingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/brand_accent"
        android:visibility="gone" />

    <!-- الشريط العلوي -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_gradient_top"
        android:orientation="vertical"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="10dp">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_back"
                android:contentDescription="@string/back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/videoTitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="اسم الفيديو" />

                <TextView
                    android:id="@+id/playlistPositionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    tools:text="2 / 15" />

            </LinearLayout>

            <ImageButton
                android:id="@+id/speedButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_speed"
                android:contentDescription="@string/speed" />

            <ImageButton
                android:id="@+id/lockButton"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_unlock"
                android:contentDescription="@string/lock" />

        </LinearLayout>
    </LinearLayout>

    <!-- زر فتح القفل عند القفل -->
    <ImageButton
        android:id="@+id/unlockOnlyButton"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="20dp"
        android:background="@drawable/bg_circle_glass"
        android:src="@drawable/ic_lock"
        android:visibility="gone"
        android:contentDescription="@string/unlock" />

    <!-- الشريط السفلي -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_panel_rounded"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/currentTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                tools:text="00:00" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginHorizontal="10dp"
                android:progressTint="@color/brand_accent"
                android:progressBackgroundTint="@color/divider"
                android:thumbTint="@color/brand_accent" />

            <TextView
                android:id="@+id/totalTimeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                tools:text="00:00" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="10dp">

            <ImageButton
                android:id="@+id/previousButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_previous"
                android:contentDescription="@string/previous" />

            <ImageButton
                android:id="@+id/rewindButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="18dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_rewind10"
                android:contentDescription="@string/rewind" />

            <ImageButton
                android:id="@+id/playPauseButton"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="22dp"
                android:background="@drawable/bg_play_button_gradient"
                android:src="@drawable/ic_pause"
                android:padding="16dp"
                android:contentDescription="@string/play" />

            <ImageButton
                android:id="@+id/forwardButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_forward10"
                android:contentDescription="@string/forward" />

            <ImageButton
                android:id="@+id/nextButton"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="18dp"
                android:background="@drawable/ripple_circle"
                android:src="@drawable/ic_next"
                android:contentDescription="@string/next" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
